;
;   Dirigeants
;
;   dirigeant, femme, couleur, style, pluriel, adjectif, ...
;           ...attaquer, accroître, civiliser, ...
;           ...gouvt, homme, femme...<répéter>
;
;   femme :     0 = homme           1 = femme
;
;   couleur :  Assortiment de couleurs (1 - 7)
;   style :    Style de ville         (0 - 3)
;             0 = Age de Bronze
;             1 = Classique
;             2 = Extręme-Orient
;             3 = Médiéval
;
;   Attaque :     1 = agressive      -1 = rationnelle
;   accroître :   1 = expansionniste  -1 = perfectionniste
;   civiliser :   1 = civilisé       -1   = militariste
;
;   govt = type de gouvernement permettant le changement de nom (0 = Anarchie, 6 = Démocratie)
;
;   homme, femme = titres pour dirigeant du gouvernement
;
